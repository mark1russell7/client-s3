# AWS S3 Credentials
# Copy this to .env and fill in your values
# NEVER commit .env to version control
#
# Static credentials are OPTIONAL. Leave AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY
# unset to use an IAM role / SSO / shared profile via the AWS SDK default chain.

AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_SESSION_TOKEN=your_session_token   # Required for STS/SSO temporary credentials
AWS_REGION=us-east-1

# Optional: Custom S3 endpoint (for MinIO, LocalStack, etc.)
# S3_ENDPOINT=http://localhost:9000
